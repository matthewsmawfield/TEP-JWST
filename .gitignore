# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo

# OS
.DS_Store
Thumbs.db

# Env / secrets
.env*
.env.local
*.pem
*.key
credentials.json
*secret*.json

# Large binaries and archives
*.tar
*.tar.gz
*.npz
*.zip
*.7z

# Build artifacts
site/node_modules/
site/dist/

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
.DS_Store

# Temporary files
*.tmp
*.temp

tmp/

# Data & Large Results
# Exclude large downloadable data files (pipeline will download these)
data/raw/**/*.fits
data/raw/**/*.fits.gz
data/raw/**/*.tar.gz
data/raw/**/*.zip
data/raw/**/*.csv.gz
data/raw/**/*.pdf
data/raw/**/*.png

# Keep small metadata/config files
!data/raw/**/*.json
!data/raw/**/*.txt
!data/raw/**/*.yaml

# Ignore massive result files
results/**/*.fits
results/**/*.hdf5

# Development scratch scripts (one-off exploration/fix scripts)
_scratch/

# Private research notes (should never be committed)
research
.windsurf
# IDE files
*.code-workspace
